{
  "name": "@statusbeam/worker",
  "type": "module",
  "version": "0.0.0",
  "description": "StatusBeam check Worker — probes your services on a cron and writes results to D1 + KV.",
  "license": "MIT",
  "homepage": "https://github.com/pleaseai/statusbeam/tree/main/apps/worker#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pleaseai/statusbeam.git",
    "directory": "apps/worker"
  },
  "files": [
    "schema.sql",
    "src",
    "wrangler.jsonc"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "statusbeam": {
    "kind": "worker",
    "entry": "./src/index.ts",
    "wrangler": "./wrangler.jsonc",
    "schema": "./schema.sql"
  },
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "db:apply": "wrangler d1 execute statusbeam --file=./schema.sql",
    "db:apply:remote": "wrangler d1 execute statusbeam --remote --file=./schema.sql --yes",
    "kv:config": "wrangler kv key put config --binding=STATUS_KV --path=../../status.config.yml --remote"
  },
  "dependencies": {
    "@statusbeam/core": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260707.1",
    "wrangler": "^4"
  }
}
