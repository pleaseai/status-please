---
import type { Locale } from '@status-please/core'
import type { StatusPageData } from '../lib/page'
import { DEFAULT_LOCALE, getDict, LOCALES } from '@status-please/core'
import '../styles/global.css'
import { IncidentList } from './IncidentList'
import { StatusBanner } from './StatusBanner'
import { StatusList } from './StatusList'
import { ThemeToggle } from './ThemeToggle'

// The locale is fixed by the page's URL prefix (/en/, /ja/, …). Each localized
// page under src/pages/<locale>/ loads the data + cache headers (see
// lib/page.ts) and renders this shared component, so there is exactly one page
// implementation across all languages.
interface Props extends StatusPageData {
  locale: Locale
}
const { locale, summary, incidents, overall } = Astro.props

const t = getDict(locale)

// Native language endonyms for the footer switcher — always shown in their own
// language so a visitor can find theirs regardless of the current UI language.
const LOCALE_NAMES: Record<Locale, string> = {
  en: 'English',
  ja: '日本語',
  ko: '한국어',
  zh: '中文',
}

// Absolute URLs for the per-locale <link rel="alternate"> tags. `Astro.site`
// (if set in astro.config) is preferred; otherwise fall back to the request URL
// so the origin is still correct.
const localeHref = (l: string): string => new URL(`/${l}/`, Astro.site ?? Astro.url).href
---

<html lang={locale} class="min-h-full">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{t.page.title}</title>
    {/*
      Anti-FOUC: apply the visitor's remembered theme to <html> before first
      paint so a forced light/dark choice never flashes the system default.
      Kept in sync with ThemeToggle.tsx (same storage key + class contract).
    */}
    <script is:inline>
      try {
        var t = localStorage.getItem('theme')
        if (t === 'light' || t === 'dark') {
          document.documentElement.classList.add(t)
        }
      } catch (e) {}
    </script>
    {/* Multilingual SEO: tell crawlers these four URLs are translations of each
        other, with English as the x-default landing. */}
    {LOCALES.map(l => (
      <link rel="alternate" hreflang={l} href={localeHref(l)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={localeHref(DEFAULT_LOCALE)} />
  </head>
  <body class="min-h-full">
    <main class="mx-auto max-w-3xl px-4 py-10">
      {/* Interactive (theme cycle): hydrates as a React island. Right-aligned
          above the banner, the conventional spot for a theme control. */}
      <div class="mb-4 flex justify-end">
        <ThemeToggle locale={locale} client:load />
      </div>

      {/* Static: renders to HTML with 0 JS (shadcn Alert via React SSR). */}
      <div class="mb-8">
        <StatusBanner severity={overall} locale={locale} />
      </div>

      {/* Interactive (uptime tooltips): hydrates as a React island. */}
      <StatusList summary={summary} locale={locale} client:visible />

      {/* Static: relative times are computed at edge render, so 0 JS ships. */}
      <section class="mt-10">
        <h2 class="mb-4 text-sm font-medium tracking-wide text-muted-foreground uppercase">{t.incidents.heading}</h2>
        <IncidentList incidents={incidents} locale={locale} />
      </section>

      <footer class="mt-10 space-y-3 text-center text-xs text-muted-foreground">
        <nav class="flex flex-wrap items-center justify-center gap-x-3 gap-y-1" aria-label={t.a11y.languageNav}>
          {LOCALES.map(l => (
            l === locale
              ? <span class="font-medium text-foreground" aria-current="true">{LOCALE_NAMES[l]}</span>
              : (
                  // `lang={l}` so AT announces each endonym in its own language
                  // (WCAG 3.1.2), since the link text differs from the page lang.
                  <a class="underline underline-offset-4 hover:text-foreground" href={`/${l}/`} hreflang={l} lang={l}>{LOCALE_NAMES[l]}</a>
                )
          ))}
        </nav>
        <p>
          Powered by <a class="underline underline-offset-4" href="https://github.com/pleaseai/status-please">status-please</a>
        </p>
      </footer>
    </main>

    {/*
      Remember the current language for the next bare-`/` visit. Written client
      side (not via Set-Cookie) so it never disables the edge cache; identical
      for every visitor of this locale, so it's safe to cache in the HTML.
    */}
    <script is:inline define:vars={{ locale }}>
      document.cookie = `locale=${locale};path=/;max-age=31536000;samesite=lax;secure`
    </script>
  </body>
</html>
