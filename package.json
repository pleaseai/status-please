{
  "name": "status-please",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "description": "Open-source, CDN-native status page generator — a modern successor to upptime.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pleaseai/status-please.git"
  },
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter '@status-please/web' dev",
    "build": "bun run --filter '*' build",
    "lint": "eslint .",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test"
  },
  "devDependencies": {
    "@pleaseai/eslint-config": "^0.0.4",
    "@types/bun": "^1.3.14",
    "eslint": "^9.10.0",
    "typescript": "^5.6"
  }
}
