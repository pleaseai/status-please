{
  "name": "statusbeam",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "description": "Open-source, CDN-native status page generator — a modern take on upptime.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pleaseai/statusbeam.git"
  },
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "eslint .",
    "typecheck": "turbo run typecheck",
    "test": "bun test",
    "setup": "bash scripts/setup.sh",
    "deploy": "bun run --filter '@statusbeam/worker' deploy && bun run --filter '@statusbeam/web' deploy"
  },
  "devDependencies": {
    "@pleaseai/eslint-config": "^0.0.4",
    "@types/bun": "^1.3.14",
    "eslint": "^10.6.0",
    "turbo": "^2.10.4",
    "typescript": "^7.0"
  }
}
