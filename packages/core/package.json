{
  "name": "@statusbeam/core",
  "type": "module",
  "version": "1.0.0",
  "description": "Shared library for StatusBeam — config schema, check logic, uptime math, badges, and i18n.",
  "license": "MIT",
  "homepage": "https://github.com/pleaseai/statusbeam/tree/main/packages/core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pleaseai/statusbeam.git",
    "directory": "packages/core"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "!src/**/*.test.ts"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "bun build ./src/index.ts --outdir dist --target node --format esm --external yaml --external zod && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "yaml": "^2.5.0",
    "zod": "^4.4.3"
  }
}
